// HRMS Platform — Prisma Schema v6
// Multi-tenant with PostgreSQL Row-Level Security (RLS)
// India-first: PF, ESI, PT, TDS, Gratuity fields included from Day 1

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  HR
  MANAGER
  EMPLOYEE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  CONSULTANT
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_NOTICE
  TERMINATED
  ABSCONDED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  WFH
  ON_LEAVE
  HOLIDAY
  WEEKEND
  PENDING
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  WITHDRAWN
}

enum LeaveSession {
  FIRST_HALF
  SECOND_HALF
}

enum PayrollRunStatus {
  DRAFT
  PROCESSING
  COMPLETED
  PAID
  FAILED
}

enum NotificationType {
  ATTENDANCE_PUNCH_IN
  ATTENDANCE_PUNCH_OUT
  LEAVE_APPLIED
  LEAVE_APPROVED
  LEAVE_REJECTED
  PAYSLIP_GENERATED
  SALARY_REVISED
  ANNOUNCEMENT
  SYSTEM
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DocumentType {
  OFFER_LETTER
  APPOINTMENT_LETTER
  PAYSLIP
  FORM_16
  EXPERIENCE_LETTER
  RELIEVING_LETTER
  ID_PROOF
  ADDRESS_PROOF
  EDUCATIONAL
  OTHER
}

enum CycleFrequency {
  ANNUAL
  HALF_YEARLY
  QUARTERLY
}

enum CycleStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum GoalStatus {
  NOT_STARTED
  IN_PROGRESS
  ACHIEVED
  MISSED
}

enum ApplicationStage {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

enum ReviewStatus {
  PENDING
  SELF_SUBMITTED
  MANAGER_REVIEWED
  COMPLETED
}

enum JobStatus {
  OPEN
  FILLED
  CLOSED
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum OffboardingTaskStatus {
  PENDING
  COMPLETED
  SKIPPED
}

enum OffboardingStatus {
  INITIATED
  IN_PROGRESS
  COMPLETED
}

enum SubscriptionPlan {
  FREE
  STARTER
  GROWTH
  ENTERPRISE
}

enum PunchMethod {
  FINGERPRINT
  FACE_ID
  MANUAL
}

enum BiometricPreference {
  FINGERPRINT_FIRST
  FACE_FIRST
  BIOMETRIC_ANY
  NO_BIOMETRIC
}

// ─────────────────────────────────────────────────────────────
// ORGANIZATIONS (Tenants)
// ─────────────────────────────────────────────────────────────

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  logoUrl     String?
  website     String?
  email       String
  phone       String?
  addressLine1 String?
  addressLine2 String?
  city        String?
  state       String?
  pincode     String?
  country     String   @default("IN")
  gstin       String?
  pan         String?
  cin         String?
  timezone    String   @default("Asia/Kolkata")
  currency    String   @default("INR")
  fiscalYearStart Int  @default(4) // April = 4
  pfEnabled   Boolean  @default(true)
  esiEnabled  Boolean  @default(true)
  ptEnabled   Boolean  @default(false)
  ptState     String?
  plan        SubscriptionPlan @default(FREE)
  maxEmployees Int             @default(10)
  trialEndsAt DateTime?
  isActive    Boolean  @default(true)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees       Employee[]
  departments     Department[]
  shifts          Shift[]
  leaveTypes      LeaveType[]
  salaryComponents SalaryComponent[]
  holidays        Holiday[]
  announcements   Announcement[]
  payrollRuns     PayrollRun[]
  notifications           Notification[]
  officeLocations         OfficeLocation[]
  performanceCycles       PerformanceCycle[]
  performanceGoals        PerformanceGoal[]
  performanceReviews      PerformanceReview[]
  peerFeedbacks           PeerFeedback[]
  jobPostings             JobPosting[]
  offboardingTemplates    OffboardingTemplate[]
  offboardingAssignments  OffboardingAssignment[]
  expenseClaims           ExpenseClaim[]
  kudos                   Kudos[]

  @@map("organizations")
}

// ─────────────────────────────────────────────────────────────
// SUPER ADMIN
// ─────────────────────────────────────────────────────────────

model SuperAdmin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("super_admins")
}

// ─────────────────────────────────────────────────────────────
// DEPARTMENTS & TEAMS
// ─────────────────────────────────────────────────────────────

model Department {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  code           String
  description    String?
  headId         String?
  parentId       String?
  isActive       Boolean   @default(true)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  parent       Department?  @relation("DeptHierarchy", fields: [parentId], references: [id])
  children     Department[] @relation("DeptHierarchy")
  teams        Team[]
  employees    Employee[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("departments")
}

model Team {
  id             String    @id @default(uuid())
  organizationId String
  departmentId   String
  name           String
  leadId         String?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  department Department @relation(fields: [departmentId], references: [id])
  employees  Employee[]

  @@index([organizationId])
  @@index([departmentId])
  @@map("teams")
}

// ─────────────────────────────────────────────────────────────
// EMPLOYEES
// ─────────────────────────────────────────────────────────────

model Employee {
  id                  String          @id @default(uuid())
  organizationId      String
  employeeCode        String
  firstName           String
  lastName            String
  displayName         String?
  email               String          // personal
  workEmail           String          // company
  phone               String?
  dateOfBirth         DateTime?
  gender              String?
  bloodGroup          String?
  avatarUrl           String?
  role                UserRole        @default(EMPLOYEE)
  status              EmployeeStatus  @default(ACTIVE)
  employmentType      EmploymentType  @default(FULL_TIME)
  departmentId        String?
  teamId              String?
  managerId           String?
  designationId       String?
  // India statutory
  panNumber           String?
  aadhaarNumber       String?
  pfAccountNumber     String?
  esiNumber           String?
  uanNumber           String?
  // Bank
  bankAccountNumber   String?
  bankIfsc            String?
  bankName            String?
  bankBranch          String?
  // Dates
  dateOfJoining       DateTime?
  dateOfConfirmation  DateTime?
  dateOfTermination   DateTime?
  noticePeriodDays    Int             @default(30)
  // Professional
  designation         String?
  maritalStatus       String?   // SINGLE | MARRIED | DIVORCED | WIDOWED
  educationDetails    Json?     // { degree, institution, year, grade }
  experienceDetails   Json?     // { totalYears, lastCompany, lastDesignation }
  // Address
  presentAddress      Json?
  permanentAddress    Json?
  emergencyContact    Json?
  // Office location (for geofence smart punch-in)
  officeLocationId    String?
  // Biometric attendance preference
  biometricPreference BiometricPreference @default(FINGERPRINT_FIRST)
  // Auth
  passwordHash        String
  passwordChangedAt   DateTime?
  lastLoginAt         DateTime?
  isEmailVerified     Boolean         @default(false)
  refreshTokenHash    String?
  // Soft delete
  deletedAt           DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id])
  officeLocation   OfficeLocation?   @relation(fields: [officeLocationId], references: [id])
  department       Department?       @relation(fields: [departmentId], references: [id])
  team             Team?             @relation(fields: [teamId], references: [id])
  manager          Employee?         @relation("ReportsTo", fields: [managerId], references: [id])
  reportees        Employee[]        @relation("ReportsTo")
  shiftAssignments ShiftAssignment[]
  attendanceRecords AttendanceRecord[]
  leaveRequests    LeaveRequest[]
  leaveApprovals   LeaveApproval[]
  salaryRevisions          SalaryRevision[]
  payslips                 Payslip[]
  documents                Document[]
  notifications            Notification[]
  regularisations          AttendanceRegularisation[]
  compOffs                 CompOff[]
  taxDeclarations          TaxDeclaration[]
  expenseClaims            ExpenseClaim[]
  expenseReviews           ExpenseClaim[]   @relation("ExpenseReviewer")
  kudosSent                Kudos[]          @relation("KudosSent")
  kudosReceived            Kudos[]          @relation("KudosReceived")
  suggestions              SuggestionBox[]
  helpDeskTickets          HelpDeskTicket[]
  passwordResetTokens      PasswordResetToken[]
  surveyResponses          SurveyResponse[]
  onboardingAssignments    OnboardingAssignment[]
  performanceGoals         PerformanceGoal[]
  reviewsReceived          PerformanceReview[]    @relation("ReviewedEmployee")
  reviewsGiven             PerformanceReview[]    @relation("ReviewerEmployee")
  feedbacksGiven           PeerFeedback[]         @relation("FeedbackGiver")
  feedbacksReceived        PeerFeedback[]         @relation("FeedbackReceiver")
  offboardingAssignments   OffboardingAssignment[]

  @@unique([organizationId, employeeCode])
  @@unique([organizationId, workEmail])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, departmentId])
  @@map("employees")
}

// ─────────────────────────────────────────────────────────────
// SHIFTS
// ─────────────────────────────────────────────────────────────

model Shift {
  id                     String    @id @default(uuid())
  organizationId         String
  name                   String
  code                   String
  startTime              String    // HH:mm
  endTime                String    // HH:mm
  graceMinutes           Int       @default(0)
  halfDayAfterMinutes    Int       @default(240)
  absentAfterMinutes     Int       @default(480)
  breakDurationMinutes   Int       @default(60)
  isNightShift           Boolean   @default(false)
  weeklyOffDays          Json      @default("[0,6]") // 0=Sun,6=Sat
  isActive               Boolean   @default(true)
  deletedAt              DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id])
  assignments      ShiftAssignment[]
  attendanceRecords AttendanceRecord[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("shifts")
}

model ShiftAssignment {
  id             String    @id @default(uuid())
  organizationId String
  employeeId     String
  shiftId        String
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  createdAt      DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
  shift    Shift    @relation(fields: [shiftId], references: [id])

  @@index([organizationId])
  @@index([employeeId])
  @@map("shift_assignments")
}

// ─────────────────────────────────────────────────────────────
// OFFICE LOCATIONS (geofence smart punch-in)
// ─────────────────────────────────────────────────────────────

model OfficeLocation {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  address        String?
  latitude       Float
  longitude      Float
  radiusMeters   Int      @default(100)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  employees    Employee[]

  @@index([organizationId])
  @@map("office_locations")
}

// ─────────────────────────────────────────────────────────────
// ATTENDANCE
// ─────────────────────────────────────────────────────────────

model AttendanceRecord {
  id               String           @id @default(uuid())
  organizationId   String
  employeeId       String
  shiftId          String?
  date             DateTime         @db.Date
  punchIn          DateTime?
  punchOut         DateTime?
  status           AttendanceStatus @default(PENDING)
  punchInLocation  Json?            // { lat, lng, accuracy, address }
  punchOutLocation Json?
  punchInPhoto     String?          // Cloudinary URL
  punchMethod      PunchMethod?     // how employee authenticated for this punch
  workingMinutes   Int              @default(0)
  overtimeMinutes  Int              @default(0)
  lateMinutes      Int              @default(0)
  isManuallyEdited Boolean          @default(false)
  editReason       String?
  editedBy         String?
  remarks          String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
  shift    Shift?   @relation(fields: [shiftId], references: [id])

  @@unique([organizationId, employeeId, date])
  @@index([organizationId, date])
  @@index([organizationId, employeeId])
  @@map("attendance_records")
}

// ─────────────────────────────────────────────────────────────
// LEAVE TYPES & REQUESTS
// ─────────────────────────────────────────────────────────────

model LeaveType {
  id              String    @id @default(uuid())
  organizationId  String
  name            String
  code            String
  daysAllowed     Int
  isCarryForward  Boolean   @default(false)
  maxCarryForward Int       @default(0)
  isPaid          Boolean   @default(true)
  isEncashable    Boolean   @default(false)
  applicableAfterDays Int   @default(0)
  colorHex        String    @default("#6366f1")
  isActive        Boolean   @default(true)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization   Organization   @relation(fields: [organizationId], references: [id])
  leaveRequests  LeaveRequest[]
  leaveBalances  LeaveBalance[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("leave_types")
}

model LeaveBalance {
  id             String    @id @default(uuid())
  organizationId String
  employeeId     String
  leaveTypeId    String
  year           Int
  allocated      Float     @default(0)
  used           Float     @default(0)
  pending        Float     @default(0)
  carried        Float     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([organizationId, employeeId, leaveTypeId, year])
  @@index([organizationId, employeeId])
  @@map("leave_balances")
}

model LeaveRequest {
  id             String      @id @default(uuid())
  organizationId String
  employeeId     String
  leaveTypeId    String
  fromDate       DateTime    @db.Date
  toDate         DateTime    @db.Date
  totalDays      Float
  reason         String
  session        LeaveSession?
  status         LeaveStatus @default(PENDING)
  attachmentUrl  String?
  deletedAt      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  employee  Employee        @relation(fields: [employeeId], references: [id])
  leaveType LeaveType       @relation(fields: [leaveTypeId], references: [id])
  approvals LeaveApproval[]

  @@index([organizationId, employeeId])
  @@index([organizationId, status])
  @@map("leave_requests")
}

model LeaveApproval {
  id             String      @id @default(uuid())
  organizationId String
  leaveRequestId String
  approverId     String
  action         LeaveStatus
  remarks        String?
  createdAt      DateTime    @default(now())

  leaveRequest LeaveRequest @relation(fields: [leaveRequestId], references: [id])
  approver     Employee     @relation(fields: [approverId], references: [id])

  @@index([leaveRequestId])
  @@map("leave_approvals")
}

// ─────────────────────────────────────────────────────────────
// SALARY & PAYROLL
// ─────────────────────────────────────────────────────────────

model SalaryComponent {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  code           String
  type           String    // EARNING | DEDUCTION | STATUTORY
  isFixedAmount  Boolean   @default(false)
  defaultPercent Float?    // % of Basic
  defaultAmount  Float?
  isTaxable      Boolean   @default(true)
  isActive       Boolean   @default(true)
  displayOrder   Int       @default(0)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("salary_components")
}

model SalaryRevision {
  id             String    @id @default(uuid())
  organizationId String
  employeeId     String
  effectiveFrom  DateTime  @db.Date
  effectiveTo    DateTime? @db.Date
  ctc            Float
  basic          Float
  gross          Float
  netPay         Float
  components     Json      // [{ componentId, code, name, amount }]
  reason         String?
  approvedBy     String?
  createdAt      DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  // Immutable — never updated, only new rows
  @@index([organizationId, employeeId])
  @@map("salary_revisions")
}

model PayrollRun {
  id               String           @id @default(uuid())
  organizationId   String
  month            Int              // 1-12
  year             Int
  status           PayrollRunStatus @default(DRAFT)
  totalEmployees   Int              @default(0)
  totalGross       Float            @default(0)
  totalDeductions  Float            @default(0)
  totalNetPay      Float            @default(0)
  processedBy      String?
  processedAt      DateTime?
  paidAt           DateTime?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  payslips     Payslip[]

  @@unique([organizationId, month, year])
  @@index([organizationId])
  @@map("payroll_runs")
}

model Payslip {
  id               String    @id @default(uuid())
  organizationId   String
  payrollRunId     String
  employeeId       String
  month            Int
  year             Int
  workingDays      Int
  presentDays      Float
  lopDays          Float     @default(0)
  earnings         Json      // [{ code, name, amount }]
  deductions       Json      // [{ code, name, amount }]
  statutory        Json      // [{ code, name, amount }]
  grossEarnings    Float
  totalDeductions  Float
  netPay           Float
  pfEmployer       Float     @default(0)
  esiEmployer      Float     @default(0)
  pdfUrl           String?   // Cloudinary URL
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id])
  employee   Employee   @relation(fields: [employeeId], references: [id])

  @@unique([organizationId, payrollRunId, employeeId])
  @@index([organizationId, employeeId])
  @@map("payslips")
}

// ─────────────────────────────────────────────────────────────
// HOLIDAYS
// ─────────────────────────────────────────────────────────────

model Holiday {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  date           DateTime @db.Date
  type           String   @default("NATIONAL") // NATIONAL | REGIONAL | OPTIONAL
  year           Int
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, date])
  @@index([organizationId, year])
  @@map("holidays")
}

// ─────────────────────────────────────────────────────────────
// ANNOUNCEMENTS
// ─────────────────────────────────────────────────────────────

model Announcement {
  id             String    @id @default(uuid())
  organizationId String
  title          String
  content        String
  authorId       String
  isPinned       Boolean   @default(false)
  visibleTo      Json      @default("[]") // [] = all, or array of role strings
  expiresAt      DateTime?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("announcements")
}

// ─────────────────────────────────────────────────────────────
// DOCUMENTS
// ─────────────────────────────────────────────────────────────

model Document {
  id             String       @id @default(uuid())
  organizationId String
  employeeId     String
  type           DocumentType
  name           String
  url            String       // Cloudinary URL
  size           Int?
  mimeType       String?
  uploadedBy     String
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([organizationId, employeeId])
  @@map("documents")
}

// ─────────────────────────────────────────────────────────────
// ATTENDANCE REGULARISATION
// ─────────────────────────────────────────────────────────────

enum RegularisationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CompOffStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

model AttendanceRegularisation {
  id             String               @id @default(uuid())
  organizationId String
  employeeId     String
  date           DateTime             @db.Date
  requestedIn    String?              // HH:mm
  requestedOut   String?              // HH:mm
  reason         String
  status         RegularisationStatus @default(PENDING)
  reviewedBy     String?
  reviewedAt     DateTime?
  remarks        String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([organizationId, employeeId])
  @@index([organizationId, status])
  @@map("attendance_regularisations")
}

// ─────────────────────────────────────────────────────────────
// COMP OFF
// ─────────────────────────────────────────────────────────────

model CompOff {
  id             String        @id @default(uuid())
  organizationId String
  employeeId     String
  workedDate     DateTime      @db.Date
  requestedDate  DateTime?     @db.Date
  reason         String
  status         CompOffStatus @default(PENDING)
  reviewedBy     String?
  reviewedAt     DateTime?
  remarks        String?
  expiresAt      DateTime?     @db.Date
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([organizationId, employeeId])
  @@index([organizationId, status])
  @@map("comp_offs")
}

// ─────────────────────────────────────────────────────────────
// TAX (IT) DECLARATION
// ─────────────────────────────────────────────────────────────

model TaxDeclaration {
  id                     String    @id @default(uuid())
  organizationId         String
  employeeId             String
  financialYear          String    // e.g. "2025-26"
  regime                 String    @default("OLD") // OLD | NEW
  // 80C investments
  ppf                    Float?
  epf                    Float?
  elss                   Float?
  lic                    Float?
  nsc                    Float?
  homeLoanPrincipal      Float?
  tuitionFees            Float?
  sukanyaSamriddhi       Float?
  // 80D health insurance
  healthInsuranceSelf    Float?
  healthInsuranceParents Float?
  // HRA
  rentPaid               Float?
  landlordPan            String?
  // Other deductions
  npsEmployee            Float?   // 80CCD(1B) — extra ₹50k
  homeLoanInterest       Float?   // 24(b)
  savingsInterest        Float?   // 80TTA
  otherDeductions        Json?    // { label: amount }
  totalDeclared          Float    @default(0)
  status                 String   @default("DRAFT") // DRAFT | SUBMITTED | VERIFIED
  submittedAt            DateTime?
  verifiedBy             String?
  verifiedAt             DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([organizationId, employeeId, financialYear])
  @@index([organizationId, employeeId])
  @@map("tax_declarations")
}

// ─────────────────────────────────────────────────────────────
// SUGGESTION BOX
// ─────────────────────────────────────────────────────────────

model SuggestionBox {
  id             String    @id @default(uuid())
  organizationId String
  employeeId     String
  title          String
  content        String
  isAnonymous    Boolean   @default(false)
  status         String    @default("OPEN") // OPEN | REVIEWED | CLOSED
  response       String?
  respondedBy    String?
  respondedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([organizationId])
  @@index([organizationId, employeeId])
  @@map("suggestion_box")
}

// ─────────────────────────────────────────────────────────────
// HR POLICIES
// ─────────────────────────────────────────────────────────────

model HrPolicy {
  id             String    @id @default(uuid())
  organizationId String
  title          String
  description    String?
  fileUrl        String
  fileSize       Int?
  mimeType       String?
  category       String    @default("GENERAL")
  version        String?
  isActive       Boolean   @default(true)
  uploadedBy     String
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId])
  @@map("hr_policies")
}

// ─────────────────────────────────────────────────────────────
// HELP DESK
// ─────────────────────────────────────────────────────────────

model HelpDeskTicket {
  id             String         @id @default(uuid())
  organizationId String
  employeeId     String
  subject        String
  description    String
  category       String         @default("GENERAL")
  status         TicketStatus   @default(OPEN)
  priority       TicketPriority @default(MEDIUM)
  assignedTo     String?
  resolvedAt     DateTime?
  closedAt       DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  employee Employee                @relation(fields: [employeeId], references: [id])
  comments HelpDeskTicketComment[]

  @@index([organizationId, status])
  @@index([organizationId, employeeId])
  @@map("helpdesk_tickets")
}

model HelpDeskTicketComment {
  id         String   @id @default(uuid())
  ticketId   String
  authorId   String
  body       String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  ticket HelpDeskTicket @relation(fields: [ticketId], references: [id])

  @@index([ticketId])
  @@map("helpdesk_ticket_comments")
}

// ─────────────────────────────────────────────────────────────
// PULSE SURVEYS
// ─────────────────────────────────────────────────────────────

model PulseSurvey {
  id             String    @id @default(uuid())
  organizationId String
  title          String
  description    String?
  status         String    @default("DRAFT") // DRAFT | ACTIVE | CLOSED
  createdBy      String
  isAnonymous    Boolean   @default(false)
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  questions SurveyQuestion[]
  responses SurveyResponse[]

  @@index([organizationId, status])
  @@map("pulse_surveys")
}

model SurveyQuestion {
  id           String   @id @default(uuid())
  surveyId     String
  questionText String
  questionType String   @default("RATING_5") // RATING_5 | RATING_10 | TEXT | MULTIPLE_CHOICE
  options      Json?
  isRequired   Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  survey  PulseSurvey    @relation(fields: [surveyId], references: [id])
  answers SurveyAnswer[]

  @@index([surveyId])
  @@map("survey_questions")
}

model SurveyResponse {
  id          String   @id @default(uuid())
  surveyId    String
  employeeId  String
  submittedAt DateTime @default(now())

  survey   PulseSurvey    @relation(fields: [surveyId], references: [id])
  employee Employee       @relation(fields: [employeeId], references: [id])
  answers  SurveyAnswer[]

  @@unique([surveyId, employeeId])
  @@index([surveyId])
  @@map("survey_responses")
}

model SurveyAnswer {
  id          String   @id @default(uuid())
  responseId  String
  questionId  String
  ratingValue Int?
  textValue   String?
  createdAt   DateTime @default(now())

  response SurveyResponse @relation(fields: [responseId], references: [id])
  question SurveyQuestion @relation(fields: [questionId], references: [id])

  @@index([responseId])
  @@index([questionId])
  @@map("survey_answers")
}

// ─────────────────────────────────────────────────────────────
// ONBOARDING
// ─────────────────────────────────────────────────────────────

model OnboardingTemplate {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  description    String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tasks       OnboardingTask[]
  assignments OnboardingAssignment[]

  @@index([organizationId])
  @@map("onboarding_templates")
}

model OnboardingTask {
  id           String   @id @default(uuid())
  templateId   String
  title        String
  description  String?
  assignedRole String   @default("HR") // HR | IT | FINANCE | MANAGER | EMPLOYEE
  dueAfterDays Int      @default(0)
  isRequired   Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  template        OnboardingTemplate        @relation(fields: [templateId], references: [id])
  assignmentTasks OnboardingAssignmentTask[]

  @@index([templateId])
  @@map("onboarding_tasks")
}

model OnboardingAssignment {
  id             String    @id @default(uuid())
  organizationId String
  employeeId     String
  templateId     String
  status         String    @default("IN_PROGRESS") // IN_PROGRESS | COMPLETED
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  employee Employee                  @relation(fields: [employeeId], references: [id])
  template OnboardingTemplate        @relation(fields: [templateId], references: [id])
  tasks    OnboardingAssignmentTask[]

  @@index([organizationId, employeeId])
  @@index([organizationId, status])
  @@map("onboarding_assignments")
}

model OnboardingAssignmentTask {
  id           String    @id @default(uuid())
  assignmentId String
  taskId       String
  title        String
  assignedRole String
  status       String    @default("PENDING") // PENDING | COMPLETED | SKIPPED
  dueDate      DateTime? @db.Date
  completedAt  DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assignment OnboardingAssignment @relation(fields: [assignmentId], references: [id])
  task       OnboardingTask       @relation(fields: [taskId], references: [id])

  @@index([assignmentId])
  @@map("onboarding_assignment_tasks")
}

// ─────────────────────────────────────────────────────────────
// PASSWORD RESET
// ─────────────────────────────────────────────────────────────

model PasswordResetToken {
  id         String    @id @default(uuid())
  employeeId String
  token      String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────────────────────

model Notification {
  id             String           @id @default(uuid())
  organizationId String
  employeeId     String
  type           NotificationType
  title          String
  body           String
  data           Json?
  isRead         Boolean          @default(false)
  readAt         DateTime?
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  employee     Employee     @relation(fields: [employeeId], references: [id])

  @@index([organizationId, employeeId, isRead])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────
// PERFORMANCE MANAGEMENT
// ─────────────────────────────────────────────────────────────

model PerformanceCycle {
  id             String         @id @default(uuid())
  organizationId String
  name           String
  frequency      CycleFrequency
  status         CycleStatus    @default(DRAFT)
  startDate      DateTime
  endDate        DateTime
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization  Organization        @relation(fields: [organizationId], references: [id])
  goals         PerformanceGoal[]
  reviews       PerformanceReview[]
  peerFeedbacks PeerFeedback[]

  @@index([organizationId])
  @@map("performance_cycles")
}

model PerformanceGoal {
  id             String     @id @default(uuid())
  organizationId String
  cycleId        String
  employeeId     String
  title          String
  description    String?
  targetValue    String?
  currentValue   Float?
  progress       Int        @default(0)
  dueDate        DateTime?  @db.Date
  status         GoalStatus @default(NOT_STARTED)
  weightage      Float      @default(1)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id])
  cycle        PerformanceCycle @relation(fields: [cycleId], references: [id])
  employee     Employee         @relation(fields: [employeeId], references: [id])

  @@index([organizationId])
  @@index([cycleId, employeeId])
  @@map("performance_goals")
}

model PerformanceReview {
  id                 String       @id @default(uuid())
  organizationId     String
  cycleId            String
  employeeId         String
  reviewerId         String?
  status             ReviewStatus @default(PENDING)
  selfRating         Float?
  selfComments       String?
  managerRating      Float?
  managerComments    String?
  finalRating        Float?
  selfSubmittedAt    DateTime?
  managerSubmittedAt DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id])
  cycle        PerformanceCycle @relation(fields: [cycleId], references: [id])
  employee     Employee         @relation("ReviewedEmployee", fields: [employeeId], references: [id])
  reviewer     Employee?        @relation("ReviewerEmployee", fields: [reviewerId], references: [id])

  @@unique([cycleId, employeeId])
  @@index([organizationId])
  @@map("performance_reviews")
}

model PeerFeedback {
  id             String   @id @default(uuid())
  organizationId String
  cycleId        String
  fromId         String
  toId           String
  rating         Float?
  strengths      String?
  improvements   String?
  createdAt      DateTime @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id])
  cycle        PerformanceCycle @relation(fields: [cycleId], references: [id])
  from         Employee         @relation("FeedbackGiver", fields: [fromId], references: [id])
  to           Employee         @relation("FeedbackReceiver", fields: [toId], references: [id])

  @@unique([cycleId, fromId, toId])
  @@index([organizationId])
  @@map("peer_feedbacks")
}

// ─────────────────────────────────────────────────────────────
// RECRUITMENT / ATS
// ─────────────────────────────────────────────────────────────

model JobPosting {
  id             String         @id @default(uuid())
  organizationId String
  title          String
  description    String
  requirements   String?
  location       String?
  employmentType EmploymentType @default(FULL_TIME)
  status         JobStatus      @default(OPEN)
  openings       Int            @default(1)
  minSalary      Float?
  maxSalary      Float?
  closingDate    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id])
  applications JobApplication[]

  @@index([organizationId])
  @@map("job_postings")
}

model JobApplication {
  id              String           @id @default(uuid())
  jobId           String
  candidateName   String
  candidateEmail  String
  candidatePhone  String?
  coverLetter     String?
  resumeUrl       String?
  source          String?
  stage           ApplicationStage @default(APPLIED)
  rejectionReason String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  job        JobPosting          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  interviews InterviewSchedule[]

  @@index([jobId])
  @@map("job_applications")
}

model InterviewSchedule {
  id              String          @id @default(uuid())
  applicationId   String
  scheduledAt     DateTime
  durationMins    Int             @default(60)
  mode            String          @default("VIDEO")
  interviewerName String?
  notes           String?
  status          InterviewStatus @default(SCHEDULED)
  feedback        String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("interview_schedules")
}

// ─────────────────────────────────────────────────────────────
// OFFBOARDING
// ─────────────────────────────────────────────────────────────

model OffboardingTemplate {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id])
  tasks        OffboardingTask[]
  assignments  OffboardingAssignment[]

  @@index([organizationId])
  @@map("offboarding_templates")
}

model OffboardingTask {
  id            String  @id @default(uuid())
  templateId    String
  title         String
  description   String?
  assignedRole  String  @default("HR")
  dueBeforeDays Int     @default(0)
  order         Int     @default(0)

  template        OffboardingTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  assignmentTasks OffboardingAssignmentTask[]

  @@index([templateId])
  @@map("offboarding_tasks")
}

model OffboardingAssignment {
  id              String            @id @default(uuid())
  organizationId  String
  employeeId      String
  templateId      String?
  lastWorkingDate DateTime
  reason          String?
  status          OffboardingStatus @default(INITIATED)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  organization  Organization              @relation(fields: [organizationId], references: [id])
  employee      Employee                  @relation(fields: [employeeId], references: [id])
  template      OffboardingTemplate?      @relation(fields: [templateId], references: [id])
  tasks         OffboardingAssignmentTask[]
  exitInterview ExitInterview?

  @@unique([organizationId, employeeId])
  @@index([organizationId])
  @@map("offboarding_assignments")
}

model OffboardingAssignmentTask {
  id           String               @id @default(uuid())
  assignmentId String
  taskId       String?
  title        String
  description  String?
  assignedRole String               @default("HR")
  dueDate      DateTime?
  status       OffboardingTaskStatus @default(PENDING)
  completedAt  DateTime?
  notes        String?

  assignment OffboardingAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  task       OffboardingTask?      @relation(fields: [taskId], references: [id])

  @@index([assignmentId])
  @@map("offboarding_assignment_tasks")
}

model ExitInterview {
  id                  String    @id @default(uuid())
  assignmentId        String    @unique
  overallRating       Float?
  workEnvironment     Float?
  managementRating    Float?
  growthOpportunities Float?
  reasonForLeaving    String?
  suggestions         String?
  wouldRejoin         Boolean?
  conductedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  assignment OffboardingAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@map("exit_interviews")
}

// ─────────────────────────────────────────────────────────────
// EXPENSE CLAIMS
// ─────────────────────────────────────────────────────────────

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  PAID
}

enum ExpenseCategory {
  TRAVEL
  FOOD
  ACCOMMODATION
  COMMUNICATION
  TRAINING
  EQUIPMENT
  MEDICAL
  OTHER
}

model ExpenseClaim {
  id             String          @id @default(uuid())
  organizationId String
  employeeId     String
  title          String
  description    String?
  category       ExpenseCategory @default(OTHER)
  amount         Float
  currency       String          @default("INR")
  receiptUrl     String?
  expenseDate    DateTime        @db.Date
  status         ExpenseStatus   @default(DRAFT)
  reviewedBy     String?
  reviewedAt     DateTime?
  reviewNote     String?
  paidAt         DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  employee     Employee     @relation(fields: [employeeId], references: [id])
  reviewer     Employee?    @relation("ExpenseReviewer", fields: [reviewedBy], references: [id])

  @@index([organizationId])
  @@index([organizationId, employeeId])
  @@map("expense_claims")
}

// ─────────────────────────────────────────────────────────────
// Peer Recognition / Kudos
// ─────────────────────────────────────────────────────────────

enum KudosCategory {
  TEAMWORK
  INNOVATION
  LEADERSHIP
  CUSTOMER_FOCUS
  GOING_ABOVE_AND_BEYOND
  PROBLEM_SOLVING
  MENTORSHIP
  OTHER
}

model Kudos {
  id             String        @id @default(uuid())
  organizationId String
  fromEmployeeId String
  toEmployeeId   String
  category       KudosCategory @default(OTHER)
  message        String
  isPublic       Boolean       @default(true)
  reactions      Json          @default("{}")
  createdAt      DateTime      @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id])
  fromEmployee   Employee     @relation("KudosSent", fields: [fromEmployeeId], references: [id])
  toEmployee     Employee     @relation("KudosReceived", fields: [toEmployeeId], references: [id])

  @@index([organizationId])
  @@index([organizationId, toEmployeeId])
  @@map("kudos")
}
