// HRMS Platform — Prisma Schema v6
// Multi-tenant with PostgreSQL Row-Level Security (RLS)
// India-first: PF, ESI, PT, TDS, Gratuity fields included from Day 1

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  HR
  MANAGER
  EMPLOYEE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  CONSULTANT
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_NOTICE
  TERMINATED
  ABSCONDED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  WFH
  ON_LEAVE
  HOLIDAY
  WEEKEND
  PENDING
}

enum LeaveStatus {
