// ─────────────────────────────────────────────────────────────
// ORGANIZATIONS (Tenants)
// ─────────────────────────────────────────────────────────────

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  logoUrl     String?
  website     String?
  email       String
  phone       String?
  addressLine1 String?
  addressLine2 String?
  city        String?
  state       String?
  pincode     String?
  country     String   @default("IN")
  gstin       String?
  pan         String?
  cin         String?
  timezone    String   @default("Asia/Kolkata")
  currency    String   @default("INR")
  fiscalYearStart Int  @default(4) // April = 4
  pfEnabled   Boolean  @default(true)
  esiEnabled  Boolean  @default(true)
  ptEnabled   Boolean  @default(false)
  ptState     String?
  plan        SubscriptionPlan @default(FREE)
  maxEmployees     Int             @default(10)
  // BUG-06 FIX: atomic sequence counter for employee codes.
  // Incremented via { increment: 1 } — no race condition possible.
  employeeSequence    Int    @default(0)
  // Org-specific employee code prefix (e.g. "SSI" → SSI-1, SSI-2, SSI-473).
  // Auto-derived from org name at registration if not explicitly set.
  // Run migration: prisma migrate dev --name "add_org_employee_code_prefix"
  employeeCodePrefix  String @default("EMP")
  trialEndsAt      DateTime?
  isActive    Boolean  @default(true)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees       Employee[]
  departments     Department[]
  shifts          Shift[]
  leaveTypes      LeaveType[]
  salaryComponents SalaryComponent[]
  holidays        Holiday[]
  announcements   Announcement[]
  payrollRuns     PayrollRun[]
  notifications           Notification[]
  officeLocations         OfficeLocation[]
  performanceCycles       PerformanceCycle[]
  performanceGoals        PerformanceGoal[]
  performanceReviews      PerformanceReview[]
  peerFeedbacks           PeerFeedback[]
  jobPostings             JobPosting[]
  offboardingTemplates    OffboardingTemplate[]
  offboardingAssignments  OffboardingAssignment[]
  expenseClaims           ExpenseClaim[]
  kudos                   Kudos[]
  eSignatureRequests      ESignatureRequest[]
  learningCourses         LearningCourse[]
  courseEnrollments       CourseEnrollment[]
  assets                  Asset[]
  assetAssignments        AssetAssignment[]
  travelRequests          TravelRequest[]
  loanRequests            LoanRequest[]
  meetingRooms            MeetingRoom[]
  roomBookings            RoomBooking[]
  wfhRequests             WFHRequest[]
  shiftSwapRequests       ShiftSwapRequest[]
  employeeReferrals       EmployeeReferral[]
  fnfSettlements          FnFSettlement[]
  // Tier 2
  salaryRevisionProposals SalaryRevisionProposal[]
  poshCases               POSHCase[]
  projects                Project[]
  timesheetEntries        TimesheetEntry[]
  benefitPlans            BenefitPlan[]
  benefitEnrollments      BenefitEnrollment[]
  pips                    PerformanceImprovementPlan[]
  nineBoxAssessments      NineBoxAssessment[]
  headcountPlans          HeadcountPlan[]
  openPositions           OpenPosition[]
  designations            Designation[]
  successionPlans         SuccessionPlan[]
  chatSessions            ChatSession[]
  // Tier 3
  ewaRequests             EwaRequest[]
  attritionScores         AttritionScore[]
  biometricDevices        BiometricDevice[]
  hiringDrives            HiringDrive[]
  payEquitySnapshots      PayEquitySnapshot[]
  interviewScorecards     InterviewScorecard[]
  parsedResumes           ParsedResume[]
  contractors             Contractor[]
  esopGrants              EsopGrant[]
  eapResources            EapResource[]
  employeeCodeRequests    EmployeeCodeChangeRequest[]

  @@map("organizations")
}

// ─────────────────────────────────────────────────────────────
// SUPER ADMIN
// ─────────────────────────────────────────────────────────────

model SuperAdmin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("super_admins")
}

// ─────────────────────────────────────────────────────────────
// EMPLOYEE CODE CHANGE REQUESTS
// Org admin requests a prefix change; super admin approves/rejects.
// ─────────────────────────────────────────────────────────────

model EmployeeCodeChangeRequest {
  id               String               @id @default(uuid())
  organizationId   String
  requestedById    String               // employee (org admin) who submitted the request
  currentPrefix    String               // snapshot of prefix at request time
  requestedPrefix  String               // what they want e.g. "SSIPL"
  applyToExisting  Boolean              @default(false) // true = retroactively rename all existing codes
  reason           String?              // optional — "company rebranded to SSIPL"
  status           EmpCodeRequestStatus @default(PENDING)
  superAdminNote   String?              // approval message or rejection reason
  resolvedAt       DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  requestedBy  Employee     @relation(fields: [requestedById], references: [id])

  @@index([organizationId, status])
  @@index([status])
  @@map("employee_code_change_requests")
}

// ─────────────────────────────────────────────────────────────
// DEPARTMENTS & TEAMS
// ─────────────────────────────────────────────────────────────

model Department {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  code           String
  description    String?
  headId         String?
  parentId       String?
  isActive       Boolean   @default(true)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  parent       Department?  @relation("DeptHierarchy", fields: [parentId], references: [id])
  children     Department[] @relation("DeptHierarchy")
  teams        Team[]
  employees    Employee[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("departments")
}

model Team {
  id             String    @id @default(uuid())
  organizationId String
  departmentId   String
  name           String
  leadId         String?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  department Department @relation(fields: [departmentId], references: [id])
  employees  Employee[]

  @@index([organizationId])
  @@index([departmentId])
  @@map("teams")
}

// ─────────────────────────────────────────────────────────────
// EMPLOYEES
// ─────────────────────────────────────────────────────────────

model Employee {
  id                  String          @id @default(uuid())
  organizationId      String
  employeeCode        String
  firstName           String
  lastName            String
  displayName         String?
  email               String          // personal
  workEmail           String          // company
  phone               String?
  dateOfBirth         DateTime?
  gender              String?
  bloodGroup          String?
  avatarUrl           String?
  role                UserRole        @default(EMPLOYEE)
  status              EmployeeStatus  @default(ACTIVE)
  employmentType      EmploymentType  @default(FULL_TIME)
  departmentId        String?
  teamId              String?
  managerId           String?
  designationId       String?
  // India statutory
  panNumber           String?
  aadhaarNumber       String?
  pfAccountNumber     String?
  esiNumber           String?
  uanNumber           String?
  // Bank
  bankAccountNumber   String?
  bankIfsc            String?
  bankName            String?
  bankBranch          String?
  // Dates
  dateOfJoining       DateTime?
  dateOfConfirmation  DateTime?
  dateOfTermination   DateTime?
  noticePeriodDays    Int             @default(30)
  // Professional
  designation         String?
  maritalStatus       String?   // SINGLE | MARRIED | DIVORCED | WIDOWED
  educationDetails    Json?     // { degree, institution, year, grade }
  experienceDetails   Json?     // { totalYears, lastCompany, lastDesignation }
  // Address
  presentAddress      Json?
  permanentAddress    Json?
  emergencyContact    Json?
  // Office location (for geofence smart punch-in)
  officeLocationId    String?
  // Biometric attendance preference
  biometricPreference BiometricPreference @default(FINGERPRINT_FIRST)
  // FCM push notification token
  fcmToken            String?
  // Auth
  passwordHash        String
  passwordChangedAt   DateTime?
  lastLoginAt         DateTime?
  isEmailVerified     Boolean         @default(false)
  refreshTokenHash    String?
  // Soft delete
  deletedAt           DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id])
  officeLocation   OfficeLocation?   @relation(fields: [officeLocationId], references: [id])
  department       Department?       @relation(fields: [departmentId], references: [id])
  team             Team?             @relation(fields: [teamId], references: [id])
  manager          Employee?         @relation("ReportsTo", fields: [managerId], references: [id])
  reportees        Employee[]        @relation("ReportsTo")
  shiftAssignments ShiftAssignment[]
  attendanceRecords AttendanceRecord[]
  leaveRequests    LeaveRequest[]
  leaveApprovals   LeaveApproval[]
  salaryRevisions          SalaryRevision[]
  payslips                 Payslip[]
  documents                Document[]
  notifications            Notification[]
  regularisations          AttendanceRegularisation[]
  compOffs                 CompOff[]
  taxDeclarations          TaxDeclaration[]
  expenseClaims            ExpenseClaim[]
  expenseReviews           ExpenseClaim[]   @relation("ExpenseReviewer")
  kudosSent                Kudos[]          @relation("KudosSent")
  kudosReceived            Kudos[]          @relation("KudosReceived")
  eSignatureRequests       ESignatureRequest[] @relation("ESignatureRequester")
  eSignaturesToSign        ESignatureRequest[] @relation("ESignatureSigner")
  courseEnrollments        CourseEnrollment[]
  coursesCreated           LearningCourse[]    @relation("CourseCreator")
  suggestions              SuggestionBox[]
  helpDeskTickets          HelpDeskTicket[]
  passwordResetTokens      PasswordResetToken[]
  surveyResponses          SurveyResponse[]
  onboardingAssignments    OnboardingAssignment[]
  performanceGoals         PerformanceGoal[]
  reviewsReceived          PerformanceReview[]    @relation("ReviewedEmployee")
  reviewsGiven             PerformanceReview[]    @relation("ReviewerEmployee")
  feedbacksGiven           PeerFeedback[]         @relation("FeedbackGiver")
  feedbacksReceived        PeerFeedback[]         @relation("FeedbackReceiver")
  offboardingAssignments   OffboardingAssignment[]
  assetAssignments         AssetAssignment[]
  travelRequests           TravelRequest[]
  travelApprovals          TravelRequest[]  @relation("TravelApprover")
  loanRequests             LoanRequest[]
  loanApprovals            LoanRequest[]    @relation("LoanApprover")
  roomBookings             RoomBooking[]
  wfhRequests              WFHRequest[]
  wfhApprovals             WFHRequest[]         @relation("WFHApprover")
  shiftSwapRequests        ShiftSwapRequest[]   @relation("SwapRequester")
  shiftSwapTargets         ShiftSwapRequest[]   @relation("SwapTarget")
  shiftSwapApprovals       ShiftSwapRequest[]   @relation("SwapApprover")
  referralsMade            EmployeeReferral[]
  fnfSettlements           FnFSettlement[]
  fnfApprovals             FnFSettlement[]      @relation("FnFApprover")
  // Tier 2
  salaryRevisionProposals      SalaryRevisionProposal[] @relation("RevisionEmployee")
  salaryRevisionProposalsOwned SalaryRevisionProposal[] @relation("RevisionProposer")
  salaryRevisionApprovals      SalaryRevisionProposal[] @relation("RevisionApprover")
  poshCases                POSHCase[]
  poshCaseUpdates          POSHCaseUpdate[]
  timesheetEntries         TimesheetEntry[]
  timesheetApprovals       TimesheetEntry[]     @relation("TimesheetApprover")
  benefitEnrollments       BenefitEnrollment[]
  pips                     PerformanceImprovementPlan[] @relation("PIPEmployee")
  managedPips              PerformanceImprovementPlan[] @relation("PIPManager")
  nineBoxAssessments       NineBoxAssessment[]  @relation("NineBoxEmployee")
  nineBoxAssessmentsGiven  NineBoxAssessment[]  @relation("NineBoxAssessor")
  successorNominations     SuccessorNomination[]
  policyAcknowledgments    PolicyAcknowledgment[]
  ewaRequests              EwaRequest[]
  attritionScore           AttritionScore?
  esopGrants               EsopGrant[]
  employeeCodeRequests     EmployeeCodeChangeRequest[]

  @@unique([organizationId, employeeCode])
  @@unique([organizationId, workEmail])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, departmentId])
  @@map("employees")
}

// ─────────────────────────────────────────────────────────────
// SHIFTS
// ─────────────────────────────────────────────────────────────

model Shift {
  id                     String    @id @default(uuid())
  organizationId         String
  name                   String
  code                   String
  startTime              String    // HH:mm
  endTime                String    // HH:mm
  graceMinutes           Int       @default(0)
  halfDayAfterMinutes    Int       @default(240)
  absentAfterMinutes     Int       @default(480)
  breakDurationMinutes   Int       @default(60)
  isNightShift           Boolean   @default(false)
  weeklyOffDays          Json      @default("[0,6]") // 0=Sun,6=Sat
  isActive               Boolean   @default(true)
  deletedAt              DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id])
  assignments      ShiftAssignment[]
  attendanceRecords AttendanceRecord[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("shifts")
}

model ShiftAssignment {
  id             String    @id @default(uuid())
  organizationId String
  employeeId     String
  shiftId        String
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  createdAt      DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
  shift    Shift    @relation(fields: [shiftId], references: [id])

  @@index([organizationId])
  @@index([employeeId])
  @@map("shift_assignments")
}

// ─────────────────────────────────────────────────────────────
// OFFICE LOCATIONS (geofence smart punch-in)
// ─────────────────────────────────────────────────────────────

model OfficeLocation {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  address        String?
  latitude       Float
  longitude      Float
  radiusMeters   Int      @default(100)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  employees    Employee[]

  @@index([organizationId])
  @@map("office_locations")
}

// ─────────────────────────────────────────────────────────────
// ATTENDANCE
// ─────────────────────────────────────────────────────────────

model AttendanceRecord {
  id               String           @id @default(uuid())
  organizationId   String
  employeeId       String
  shiftId          String?
  date             DateTime         @db.Date
  punchIn          DateTime?
  punchOut         DateTime?
  status           AttendanceStatus @default(PENDING)
  punchInLocation  Json?            // { lat, lng, accuracy, address }
  punchOutLocation Json?
  punchInPhoto     String?          // Cloudinary URL
  punchMethod      PunchMethod?     // how employee authenticated for this punch
  workingMinutes   Int              @default(0)
  overtimeMinutes  Int              @default(0)
  lateMinutes      Int              @default(0)
  isManuallyEdited Boolean          @default(false)
  editReason       String?
  editedBy         String?
  remarks          String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
  shift    Shift?   @relation(fields: [shiftId], references: [id])

  @@unique([organizationId, employeeId, date])
  @@index([organizationId, date])
  @@index([organizationId, employeeId])
  @@map("attendance_records")
}

// ─────────────────────────────────────────────────────────────
// LEAVE TYPES & REQUESTS
// ─────────────────────────────────────────────────────────────

model LeaveType {
  id              String    @id @default(uuid())
  organizationId  String
  name            String
  code            String
  daysAllowed     Int
  isCarryForward  Boolean   @default(false)
  maxCarryForward Int       @default(0)
  isPaid          Boolean   @default(true)
  isEncashable    Boolean   @default(false)
  applicableAfterDays Int   @default(0)
  colorHex        String    @default("#6366f1")
  isActive        Boolean   @default(true)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization   Organization   @relation(fields: [organizationId], references: [id])
  leaveRequests  LeaveRequest[]
  leaveBalances  LeaveBalance[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("leave_types")
}

model LeaveBalance {
  id             String    @id @default(uuid())
  organizationId String
  employeeId     String
  leaveTypeId    String
  year           Int
  allocated      Float     @default(0)
  used           Float     @default(0)
  pending        Float     @default(0)
  carried        Float     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([organizationId, employeeId, leaveTypeId, year])
  @@index([organizationId, employeeId])
  @@map("leave_balances")
}

model LeaveRequest {
  id             String      @id @default(uuid())
  organizationId String
  employeeId     String
  leaveTypeId    String
  fromDate       DateTime    @db.Date
  toDate         DateTime    @db.Date
  totalDays      Float
  reason         String
  session        LeaveSession?
  status         LeaveStatus @default(PENDING)
  attachmentUrl  String?
  deletedAt      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  employee  Employee        @relation(fields: [employeeId], references: [id])
  leaveType LeaveType       @relation(fields: [leaveTypeId], references: [id])
  approvals LeaveApproval[]

  @@index([organizationId, employeeId])
  @@index([organizationId, status])
  @@map("leave_requests")
}

model LeaveApproval {
  id             String      @id @default(uuid())
  organizationId String
  leaveRequestId String
  approverId     String
  action         LeaveStatus
  remarks        String?
  createdAt      DateTime    @default(now())

  leaveRequest LeaveRequest @relation(fields: [leaveRequestId], references: [id])
  approver     Employee     @relation(fields: [approverId], references: [id])

  @@index([leaveRequestId])
  @@map("leave_approvals")
}

// ─────────────────────────────────────────────────────────────
// SALARY & PAYROLL
// ─────────────────────────────────────────────────────────────

model SalaryComponent {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  code           String
  type           String    // EARNING | DEDUCTION | STATUTORY
  isFixedAmount  Boolean   @default(false)
  defaultPercent Float?    // % of Basic
  defaultAmount  Float?
  isTaxable      Boolean   @default(true)
  isActive       Boolean   @default(true)
  displayOrder   Int       @default(0)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("salary_components")
}

model SalaryRevision {
  id             String    @id @default(uuid())
  organizationId String
  employeeId     String
  effectiveFrom  DateTime  @db.Date
  effectiveTo    DateTime? @db.Date
  ctc            Float
  basic          Float
  gross          Float
  netPay         Float
  components     Json      // [{ componentId, code, name, amount }]
  reason         String?
  approvedBy     String?
  createdAt      DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  // Immutable — never updated, only new rows
  @@index([organizationId, employeeId])
  // PERF-01: Payroll bulk fetch filters by (organizationId, effectiveFrom <=) —
  // this index makes the scan fast even when an org has thousands of revisions.
  @@index([organizationId, effectiveFrom])
  @@map("salary_revisions")
}

model PayrollRun {
  id               String           @id @default(uuid())
  organizationId   String
  month            Int              // 1-12
  year             Int
  status           PayrollRunStatus @default(DRAFT)
  totalEmployees   Int              @default(0)
  totalGross       Float            @default(0)
  totalDeductions  Float            @default(0)
  totalNetPay      Float            @default(0)
  processedBy      String?
  processedAt      DateTime?
  paidAt           DateTime?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  payslips     Payslip[]

  @@unique([organizationId, month, year])
  @@index([organizationId])
  @@map("payroll_runs")
}

model Payslip {
  id               String    @id @default(uuid())
  organizationId   String
  payrollRunId     String
  employeeId       String
  month            Int
  year             Int
  workingDays      Int
  presentDays      Float
  lopDays          Float     @default(0)
  earnings         Json      // [{ code, name, amount }]
  deductions       Json      // [{ code, name, amount }]
  statutory        Json      // [{ code, name, amount }]
  grossEarnings    Float
  totalDeductions  Float
  netPay           Float
  pfEmployer       Float     @default(0)
  esiEmployer      Float     @default(0)
  pdfUrl           String?   // Cloudinary URL
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id])
  employee   Employee   @relation(fields: [employeeId], references: [id])

  @@unique([organizationId, payrollRunId, employeeId])
  @@index([organizationId, employeeId])
  // PERF-01: Payroll run detail page queries payslips by (orgId, payrollRunId) —
  // PostgreSQL can use the unique constraint as a prefix scan but an explicit
  // index keeps query plans predictable without relying on constraint internals.
  @@index([organizationId, payrollRunId])
  @@map("payslips")
}

