enum EnrollmentStatus {
  ENROLLED
  IN_PROGRESS
  COMPLETED
  DROPPED
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model LearningCourse {
  id               String       @id @default(uuid())
  organizationId   String
  title            String
  description      String?
  thumbnailUrl     String?
  category         String       @default("General")
  level            CourseLevel  @default(BEGINNER)
  durationMinutes  Int          @default(0)
  status           CourseStatus @default(DRAFT)
  createdById      String
  tags             String[]
  externalUrl      String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id])
  createdBy    Employee         @relation("CourseCreator", fields: [createdById], references: [id])
  enrollments  CourseEnrollment[]

  @@index([organizationId])
  @@map("learning_courses")
}

model CourseEnrollment {
  id             String           @id @default(uuid())
  organizationId String
  courseId       String
  employeeId     String
  status         EnrollmentStatus @default(ENROLLED)
  progressPct    Int              @default(0)
  completedAt    DateTime?
  enrolledAt     DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id])
  course       LearningCourse @relation(fields: [courseId], references: [id])
  employee     Employee       @relation(fields: [employeeId], references: [id])

  @@unique([courseId, employeeId])
  @@index([organizationId, employeeId])
  @@map("course_enrollments")
}

// ─────────────────────────────────────────────────────────────
// ASSET MANAGEMENT
// ─────────────────────────────────────────────────────────────

model Asset {
  id             String        @id @default(uuid())
  organizationId String
  name           String
  category       AssetCategory @default(OTHER)
  serialNumber   String?
  brand          String?
  model          String?
  purchaseDate   DateTime?
  purchasePrice  Decimal?      @db.Decimal(12, 2)
  warrantyExpiry DateTime?
  status         AssetStatus   @default(AVAILABLE)
  notes          String?
  imageUrl       String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id])
  assignments  AssetAssignment[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@map("assets")
}

model AssetAssignment {
  id             String    @id @default(uuid())
  organizationId String
  assetId        String
  employeeId     String
  assignedAt     DateTime  @default(now())
  returnedAt     DateTime?
  condition      String?
  notes          String?

  organization Organization @relation(fields: [organizationId], references: [id])
  asset        Asset        @relation(fields: [assetId], references: [id])
  employee     Employee     @relation(fields: [employeeId], references: [id])

  @@index([organizationId, assetId])
  @@index([organizationId, employeeId])
  @@map("asset_assignments")
}

// ─────────────────────────────────────────────────────────────
// TRAVEL REQUESTS
// ─────────────────────────────────────────────────────────────

model TravelRequest {
  id               String        @id @default(uuid())
  organizationId   String
  employeeId       String
  purpose          String
  fromCity         String
  toCity           String
  departureDate    DateTime
  returnDate       DateTime?
  travelMode       TravelMode    @default(FLIGHT)
  estimatedBudget  Decimal?      @db.Decimal(12, 2)
  hotelRequired    Boolean       @default(false)
  advanceRequired  Boolean       @default(false)
  advanceAmount    Decimal?      @db.Decimal(12, 2)
  status           TravelStatus  @default(PENDING)
  approvedById     String?
  approvedAt       DateTime?
  rejectedReason   String?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  employee     Employee     @relation(fields: [employeeId], references: [id])
  approvedBy   Employee?    @relation("TravelApprover", fields: [approvedById], references: [id])

  @@index([organizationId, employeeId])
  @@index([organizationId, status])
  @@map("travel_requests")
}

// ─────────────────────────────────────────────────────────────
// LOAN & SALARY ADVANCE
// ─────────────────────────────────────────────────────────────

model LoanRequest {
  id              String      @id @default(uuid())
  organizationId  String
  employeeId      String
  loanType        LoanType
  amount          Decimal     @db.Decimal(14, 2)
  tenure          Int?
  emi             Decimal?    @db.Decimal(14, 2)
  purpose         String
  status          LoanStatus  @default(PENDING)
  approvedById    String?
  approvedAt      DateTime?
  rejectedReason  String?
  disbursedAt     DateTime?
  repaidAmount    Decimal     @default(0) @db.Decimal(14, 2)
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  employee     Employee     @relation(fields: [employeeId], references: [id])
  approvedBy   Employee?    @relation("LoanApprover", fields: [approvedById], references: [id])

  @@index([organizationId, employeeId])
  @@index([organizationId, status])
  @@map("loan_requests")
}

// ─────────────────────────────────────────────────────────────
// MEETING ROOM BOOKING
// ─────────────────────────────────────────────────────────────

enum RoomBookingStatus {
  CONFIRMED
  CANCELLED
}

model MeetingRoom {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  location       String?
  capacity       Int      @default(1)
  amenities      String[] @default([])
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id])
  bookings     RoomBooking[]

  @@index([organizationId])
  @@map("meeting_rooms")
}

model RoomBooking {
  id             String            @id @default(uuid())
  organizationId String
  roomId         String
  bookedById     String
  title          String
  startTime      DateTime
  endTime        DateTime
  attendees      Int               @default(1)
  notes          String?
  status         RoomBookingStatus @default(CONFIRMED)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  room         MeetingRoom  @relation(fields: [roomId], references: [id])
  bookedBy     Employee     @relation(fields: [bookedById], references: [id])

  @@index([organizationId, roomId])
  @@index([organizationId, bookedById])
  @@index([organizationId, startTime])
  @@map("room_bookings")
}

// ─────────────────────────────────────────────────────────────
// WFH REQUESTS
// ─────────────────────────────────────────────────────────────

model WFHRequest {
  id             String    @id @default(uuid())
  organizationId String
  employeeId     String
  date           DateTime  @db.Date
  reason         String?
  status         WFHStatus @default(PENDING)
  approvedById   String?
  approvedAt     DateTime?
  rejectedReason String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  employee     Employee     @relation(fields: [employeeId], references: [id])
  approvedBy   Employee?    @relation("WFHApprover", fields: [approvedById], references: [id])

  @@unique([organizationId, employeeId, date])
  @@index([organizationId, employeeId])
  @@index([organizationId, status])
  @@map("wfh_requests")
}

// ─────────────────────────────────────────────────────────────
// SHIFT SWAP REQUESTS
// ─────────────────────────────────────────────────────────────

model ShiftSwapRequest {
  id              String          @id @default(uuid())
  organizationId  String
  requesterId     String
  targetId        String
  requesterDate   DateTime        @db.Date
  targetDate      DateTime        @db.Date
  reason          String?
  status          ShiftSwapStatus @default(PENDING_ACCEPTANCE)
  targetAcceptedAt DateTime?
  approvedById    String?
  approvedAt      DateTime?
  rejectedReason  String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  requester    Employee     @relation("SwapRequester", fields: [requesterId], references: [id])
  target       Employee     @relation("SwapTarget", fields: [targetId], references: [id])
  approvedBy   Employee?    @relation("SwapApprover", fields: [approvedById], references: [id])

  @@index([organizationId, requesterId])
  @@index([organizationId, targetId])
  @@index([organizationId, status])
  @@map("shift_swap_requests")
}

// ─────────────────────────────────────────────────────────────
// EMPLOYEE REFERRALS
// ─────────────────────────────────────────────────────────────

model EmployeeReferral {
  id              String         @id @default(uuid())
  organizationId  String
  referrerId      String
  jobId           String?
  candidateName   String
  candidateEmail  String
  candidatePhone  String?
  position        String
  message         String?
  status          ReferralStatus @default(SUBMITTED)
  bonusAmount     Float?
  bonusPaid       Boolean        @default(false)
  hiredAt         DateTime?
  rejectedReason  String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id])
  referrer     Employee      @relation(fields: [referrerId], references: [id])
  job          JobPosting?   @relation(fields: [jobId], references: [id])

  @@index([organizationId, referrerId])
  @@index([organizationId, status])
  @@map("employee_referrals")
}

// ─────────────────────────────────────────────────────────────
// FULL & FINAL SETTLEMENT
// ─────────────────────────────────────────────────────────────

model FnFSettlement {
  id                String    @id @default(uuid())
  organizationId    String
  employeeId        String    @unique
  lastWorkingDate   DateTime
  basicDays         Float     @default(0)
  basicAmount       Float     @default(0)
  pendingLeavesDays Float     @default(0)
  leaveEncashment   Float     @default(0)
  gratuityYears     Float     @default(0)
  gratuityAmount    Float     @default(0)
  bonusAmount       Float     @default(0)
  otherDeductions   Float     @default(0)
  netPayable        Float     @default(0)
  notes             String?
  status            FnFStatus @default(DRAFT)
  approvedById      String?
  approvedAt        DateTime?
  paidAt            DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  employee     Employee     @relation(fields: [employeeId], references: [id])
  approvedBy   Employee?    @relation("FnFApprover", fields: [approvedById], references: [id])

  @@index([organizationId])
  @@map("fnf_settlements")
}

// ─────────────────────────────────────────────────────────────
// POLICY ACKNOWLEDGMENT TRACKING (#21)
// ─────────────────────────────────────────────────────────────

model PolicyAcknowledgment {
  id             String   @id @default(uuid())
  organizationId String
  policyId       String
  employeeId     String
  acknowledgedAt DateTime @default(now())

  policy   HrPolicy @relation(fields: [policyId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([policyId, employeeId])
  @@index([organizationId, policyId])
  @@map("policy_acknowledgments")
}

// ─────────────────────────────────────────────────────────────
// SALARY REVISION PROPOSAL / APPRAISAL WORKFLOW (#23)
// ─────────────────────────────────────────────────────────────

model SalaryRevisionProposal {
  id              String                 @id @default(uuid())
  organizationId  String
  employeeId      String
  proposedById    String
  effectiveFrom   DateTime               @db.Date
  currentCtc      Float
  proposedCtc     Float
  currentBasic    Float
  proposedBasic   Float
  currentGross    Float
  proposedGross   Float
  currentNetPay   Float
  proposedNetPay  Float
  components      Json
  reason          String
  status          RevisionProposalStatus @default(PENDING)
  approvedById    String?
  approvedAt      DateTime?
  rejectedReason  String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  employee     Employee     @relation("RevisionEmployee", fields: [employeeId], references: [id])
  proposedBy   Employee     @relation("RevisionProposer", fields: [proposedById], references: [id])
  approvedBy   Employee?    @relation("RevisionApprover", fields: [approvedById], references: [id])

  @@index([organizationId, employeeId])
  @@index([organizationId, status])
  @@map("salary_revision_proposals")
}

// ─────────────────────────────────────────────────────────────
// POSH CASE MANAGEMENT (#19)
// ─────────────────────────────────────────────────────────────

model POSHCase {
  id               String         @id @default(uuid())
  organizationId   String
  caseNumber       String
  complainantId    String
  respondentName   String
  incidentDate     DateTime       @db.Date
  incidentLocation String?
  description      String
  status           POSHCaseStatus @default(FILED)
  assignedTo       String?
  resolvedAt       DateTime?
  resolution       String?
  isAnonymous      Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id])
  complainant  Employee        @relation(fields: [complainantId], references: [id])
  updates      POSHCaseUpdate[]

  @@unique([organizationId, caseNumber])
  @@index([organizationId, status])
  @@map("posh_cases")
}

model POSHCaseUpdate {
  id        String   @id @default(uuid())
  caseId    String
  updatedBy String
  note      String
  createdAt DateTime @default(now())

  case      POSHCase @relation(fields: [caseId], references: [id])
  updatedByEmp Employee @relation(fields: [updatedBy], references: [id])

  @@index([caseId])
  @@map("posh_case_updates")
}

// ─────────────────────────────────────────────────────────────
// TIMESHEET / PROJECT TIME TRACKING (#20)
// ─────────────────────────────────────────────────────────────

model Project {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  code           String
  description    String?
  clientName     String?
  isBillable     Boolean   @default(true)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id])
  entries      TimesheetEntry[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("projects")
}

model TimesheetEntry {
  id             String          @id @default(uuid())
  organizationId String
  employeeId     String
  projectId      String
  date           DateTime        @db.Date
  hours          Float
  description    String?
  isBillable     Boolean         @default(true)
  status         TimesheetStatus @default(DRAFT)
  weekStart      DateTime        @db.Date
  approvedById   String?
  approvedAt     DateTime?
  rejectedReason String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  employee     Employee     @relation(fields: [employeeId], references: [id])
  project      Project      @relation(fields: [projectId], references: [id])
  approvedBy   Employee?    @relation("TimesheetApprover", fields: [approvedById], references: [id])

  @@index([organizationId, employeeId])
  @@index([organizationId, weekStart])
  @@map("timesheet_entries")
}

// ─────────────────────────────────────────────────────────────
// BENEFITS ADMINISTRATION (#17)
// ─────────────────────────────────────────────────────────────

model BenefitPlan {
  id                 String      @id @default(uuid())
  organizationId     String
  name               String
  type               BenefitType
  description        String?
  maxAmount          Float?
  isActive           Boolean     @default(true)
  enrollmentDeadline DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id])
  enrollments  BenefitEnrollment[]

  @@index([organizationId])
  @@map("benefit_plans")
}

model BenefitEnrollment {
  id             String                  @id @default(uuid())
  organizationId String
  planId         String
  employeeId     String
  status         BenefitEnrollmentStatus @default(PENDING)
  amount         Float?
  details        Json?
  enrolledAt     DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  plan         BenefitPlan  @relation(fields: [planId], references: [id])
  employee     Employee     @relation(fields: [employeeId], references: [id])

  @@unique([planId, employeeId])
  @@index([organizationId, employeeId])
  @@map("benefit_enrollments")
}

// ─────────────────────────────────────────────────────────────
// PERFORMANCE IMPROVEMENT PLAN (#13)
// ─────────────────────────────────────────────────────────────

model PerformanceImprovementPlan {
  id             String    @id @default(uuid())
  organizationId String
  employeeId     String
  managerId      String
  title          String
  reason         String
  startDate      DateTime  @db.Date
  endDate        DateTime  @db.Date
  status         PIPStatus @default(ACTIVE)
  outcome        String?
  closedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  employee     Employee     @relation("PIPEmployee", fields: [employeeId], references: [id])
  manager      Employee     @relation("PIPManager", fields: [managerId], references: [id])
  goals        PIPGoal[]
  checkIns     PIPCheckIn[]

  @@index([organizationId, employeeId])
  @@index([organizationId, status])
  @@map("performance_improvement_plans")
}

model PIPGoal {
  id          String     @id @default(uuid())
  pipId       String
  title       String
  description String?
  targetDate  DateTime?  @db.Date
  status      GoalStatus @default(NOT_STARTED)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  pip PerformanceImprovementPlan @relation(fields: [pipId], references: [id], onDelete: Cascade)

  @@index([pipId])
  @@map("pip_goals")
}

model PIPCheckIn {
  id          String   @id @default(uuid())
  pipId       String
  conductedAt DateTime
  notes       String?
  progress    String?
  createdAt   DateTime @default(now())

  pip PerformanceImprovementPlan @relation(fields: [pipId], references: [id], onDelete: Cascade)

  @@index([pipId])
  @@map("pip_check_ins")
}

// ─────────────────────────────────────────────────────────────
// NINE-BOX GRID (#14)
// ─────────────────────────────────────────────────────────────

model NineBoxAssessment {
  id             String   @id @default(uuid())
  organizationId String
  cycleId        String?
  employeeId     String
  assessedById   String
  performance    Int      // 1=Low 2=Medium 3=High
  potential      Int      // 1=Low 2=Medium 3=High
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id])
  employee     Employee         @relation("NineBoxEmployee", fields: [employeeId], references: [id])
  assessedBy   Employee         @relation("NineBoxAssessor", fields: [assessedById], references: [id])

  @@unique([organizationId, cycleId, employeeId])
  @@index([organizationId])
  @@map("nine_box_assessments")
}

// ─────────────────────────────────────────────────────────────
// HEADCOUNT / WORKFORCE PLANNING (#18)
// ─────────────────────────────────────────────────────────────

model HeadcountPlan {
  id             String    @id @default(uuid())
  organizationId String
  departmentId   String?
  financialYear  String
  budgetedCount  Int
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id])
  openPositions OpenPosition[]

  @@unique([organizationId, departmentId, financialYear])
  @@index([organizationId])
  @@map("headcount_plans")
}

model OpenPosition {
  id             String             @id @default(uuid())
  organizationId String
  planId         String?
  departmentId   String?
  title          String
  count          Int                @default(1)
  status         OpenPositionStatus @default(OPEN)
  targetDate     DateTime?          @db.Date
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id])
  plan         HeadcountPlan? @relation(fields: [planId], references: [id])

  @@index([organizationId, status])
  @@map("open_positions")
}

// ─────────────────────────────────────────────────────────────
// CAREER PATH VISUALIZATION (#15)
// ─────────────────────────────────────────────────────────────

model Designation {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  level          Int      @default(1)
  department     String?
  description    String?
  skills         String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  fromPaths    CareerPath[] @relation("FromDesignation")
  toPaths      CareerPath[] @relation("ToDesignation")

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("designations")
}

model CareerPath {
  id                 String   @id @default(uuid())
  organizationId     String
  fromDesignationId  String
  toDesignationId    String
  typicalYears       Int?
  skillsRequired     String[] @default([])
  notes              String?
  createdAt          DateTime @default(now())

  fromDesignation Designation @relation("FromDesignation", fields: [fromDesignationId], references: [id])
  toDesignation   Designation @relation("ToDesignation", fields: [toDesignationId], references: [id])

  @@unique([organizationId, fromDesignationId, toDesignationId])
  @@index([organizationId])
  @@map("career_paths")
}

// ─────────────────────────────────────────────────────────────
// SUCCESSION PLANNING (#16)
// ─────────────────────────────────────────────────────────────

model SuccessionPlan {
  id             String   @id @default(uuid())
  organizationId String
  roleTitle      String
  departmentId   String?
  isCritical     Boolean  @default(true)
  riskLevel      String   @default("MEDIUM")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id])
  successors   SuccessorNomination[]

  @@index([organizationId])
  @@map("succession_plans")
}

model SuccessorNomination {
  id         String             @id @default(uuid())
  planId     String
  employeeId String
  readiness  SuccessorReadiness @default(ONE_TO_TWO_YEARS)
  notes      String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  plan     SuccessionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  employee Employee       @relation(fields: [employeeId], references: [id])

  @@unique([planId, employeeId])
  @@index([planId])
  @@map("successor_nominations")
}

// ─────────────────────────────────────────────────────────────
// AI CHATBOT SESSIONS (#24)
// ─────────────────────────────────────────────────────────────

model ChatSession {
  id             String   @id @default(uuid())
  organizationId String
  employeeId     String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id])
  messages     ChatMessage[]

  @@index([organizationId, employeeId])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String   @id @default(uuid())
  sessionId String
  role      String   // user | assistant
  content   String
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("chat_messages")
}

// ═════════════════════════════════════════════════════════════
// TIER 3 — ENTERPRISE / SCALE FEATURES
// ═════════════════════════════════════════════════════════════

// ─────────────────────────────────────────────────────────────
// T3-1. EARNED WAGE ACCESS (EWA)
// ─────────────────────────────────────────────────────────────

model EwaRequest {
  id             String    @id @default(uuid())
  organizationId String
  employeeId     String
  amount         Float
  status         EwaStatus @default(PENDING)
  requestedAt    DateTime  @default(now())
  processedAt    DateTime?
  rejectedReason String?
  repaymentDate  DateTime?
  notes          String?

  organization Organization @relation(fields: [organizationId], references: [id])
  employee     Employee     @relation(fields: [employeeId], references: [id])

  @@index([organizationId, employeeId])
  @@map("ewa_requests")
}

enum EwaStatus {
  PENDING
  APPROVED
  DISBURSED
  REJECTED
  REPAID
}

// ─────────────────────────────────────────────────────────────
// T3-2. ATTRITION PREDICTION
// ─────────────────────────────────────────────────────────────

model AttritionScore {
  id             String   @id @default(uuid())
  organizationId String
  employeeId     String   @unique
  riskScore      Float
  riskLevel      String
  factors        Json
  computedAt     DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  employee     Employee     @relation(fields: [employeeId], references: [id])

  @@index([organizationId, riskLevel])
  @@map("attrition_scores")
}

// ─────────────────────────────────────────────────────────────
// T3-3. BIOMETRIC DEVICE INTEGRATION
// ─────────────────────────────────────────────────────────────

model BiometricDevice {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  vendor         String
  serialNumber   String?
  ipAddress      String?
  location       String?
  isActive       Boolean  @default(true)
  lastSyncAt     DateTime?
  createdAt      DateTime @default(now())

  organization Organization          @relation(fields: [organizationId], references: [id])
  logs         BiometricDeviceLog[]

  @@index([organizationId])
  @@map("biometric_devices")
}

model BiometricDeviceLog {
  id         String   @id @default(uuid())
  deviceId   String
  employeeId String?
  eventType  String
  deviceTime DateTime
  receivedAt DateTime @default(now())
  raw        Json?

  device BiometricDevice @relation(fields: [deviceId], references: [id])

  @@index([deviceId, deviceTime])
  @@map("biometric_device_logs")
}

// ─────────────────────────────────────────────────────────────
// T3-4. BULK / CAMPUS HIRING
// ─────────────────────────────────────────────────────────────

model HiringDrive {
  id             String      @id @default(uuid())
  organizationId String
  name           String
  driveType      DriveType   @default(CAMPUS)
  venue          String?
  driveDate      DateTime?
  targetCount    Int         @default(0)
  status         DriveStatus @default(PLANNED)
  description    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id])
  candidates   BulkCandidate[]

  @@index([organizationId, status])
  @@map("hiring_drives")
}

enum DriveType {
  CAMPUS
  WALKIN
  REFERRAL_DRIVE
  LATERAL
}

enum DriveStatus {
  PLANNED
  ONGOING
  COMPLETED
  CANCELLED
}

model BulkCandidate {
  id          String    @id @default(uuid())
  driveId     String
  name        String
  email       String?
  phone       String?
  college     String?
  degree      String?
  cgpa        Float?
  status      String    @default("APPLIED")
  offerSentAt DateTime?
  resumeUrl   String?
  notes       String?
  createdAt   DateTime  @default(now())

  drive HiringDrive @relation(fields: [driveId], references: [id], onDelete: Cascade)

  @@index([driveId, status])
  @@map("bulk_candidates")
}

// ─────────────────────────────────────────────────────────────
// T3-5. PAY EQUITY ANALYSIS
// ─────────────────────────────────────────────────────────────

model PayEquitySnapshot {
  id             String   @id @default(uuid())
  organizationId String
  snapshotDate   DateTime @default(now())
  reportData     Json
  generatedBy    String?

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("pay_equity_snapshots")
}

// ─────────────────────────────────────────────────────────────
// T3-6. INTERVIEW SCORECARD (ATS)
// ─────────────────────────────────────────────────────────────

model InterviewScorecard {
  id             String    @id @default(uuid())
  organizationId String
  applicationId  String?
  interviewId    String?
  candidateName  String
  interviewerIds String[]
  template       Json
  scores         Json
  overallRating  Float?
  recommendation String?
  notes          String?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, applicationId])
  @@map("interview_scorecards")
}

// ─────────────────────────────────────────────────────────────
// T3-7. RESUME PARSING
// ─────────────────────────────────────────────────────────────

model ParsedResume {
  id             String   @id @default(uuid())
  organizationId String
  uploadedBy     String
  fileName       String
  fileUrl        String
  parsedData     Json?
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, status])
  @@map("parsed_resumes")
}

// ─────────────────────────────────────────────────────────────
// T3-8. CONTRACTOR / GIG WORKER MANAGEMENT
// ─────────────────────────────────────────────────────────────

model Contractor {
  id             String           @id @default(uuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  pan            String?
  gstNumber      String?
  contractType   ContractorType   @default(INDIVIDUAL)
  skills         String[]
  startDate      DateTime?
  endDate        DateTime?
  dailyRate      Float?
  currency       String           @default("INR")
  status         ContractorStatus @default(ACTIVE)
  documents      Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id])
  pos          PurchaseOrder[]

  @@index([organizationId, status])
  @@map("contractors")
}

enum ContractorType {
  INDIVIDUAL
  AGENCY
  FREELANCER
}

enum ContractorStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

model PurchaseOrder {
  id           String    @id @default(uuid())
  contractorId String
  poNumber     String
  description  String?
  amount       Float
  currency     String    @default("INR")
  startDate    DateTime?
  endDate      DateTime?
  status       String    @default("OPEN")
  invoiceUrl   String?
  createdAt    DateTime  @default(now())

  contractor Contractor @relation(fields: [contractorId], references: [id])

  @@index([contractorId, status])
  @@map("purchase_orders")
}

// ─────────────────────────────────────────────────────────────
// T3-9. ESOP / EQUITY MANAGEMENT
// ─────────────────────────────────────────────────────────────

model EsopGrant {
  id              String     @id @default(uuid())
  organizationId  String
  employeeId      String
  grantDate       DateTime
  options         Int
  strikePrice     Float
  currency        String     @default("INR")
  vestingSchedule Json
  cliffMonths     Int        @default(12)
  totalVestMonths Int        @default(48)
  status          EsopStatus @default(ACTIVE)
  notes           String?
  createdAt       DateTime   @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id])
  employee     Employee      @relation(fields: [employeeId], references: [id])
  exercises    EsopExercise[]

  @@index([organizationId, employeeId])
  @@map("esop_grants")
}

enum EsopStatus {
  ACTIVE
  VESTED
  EXERCISED
  CANCELLED
  EXPIRED
}

model EsopExercise {
  id            String   @id @default(uuid())
  grantId       String
  options       Int
  exercisePrice Float
  exercisedAt   DateTime @default(now())
  notes         String?

  grant EsopGrant @relation(fields: [grantId], references: [id])

  @@index([grantId])
  @@map("esop_exercises")
}

// ─────────────────────────────────────────────────────────────
// T3-10. MENTAL HEALTH / EAP RESOURCES
// ─────────────────────────────────────────────────────────────

model EapResource {
  id             String   @id @default(uuid())
  organizationId String
  title          String
  category       String
  description    String?
  providerName   String?
  contactEmail   String?
  contactPhone   String?
  websiteUrl     String?
  isAnonymous    Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, category])
  @@map("eap_resources")
}
