{
  "name": "@hrms/shared-utils",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./date": {
      "types": "./src/date.utils.ts",
      "import": "./dist/date.utils.js"
    },
    "./payroll": {
      "types": "./src/payroll.utils.ts",
      "import": "./dist/payroll.utils.js"
    },
    "./validation": {
      "types": "./src/validation.utils.ts",
      "import": "./dist/validation.utils.js"
    },
    "./format": {
      "types": "./src/format.utils.ts",
      "import": "./dist/format.utils.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@hrms/shared-types": "workspace:*",
    "date-fns": "catalog:"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
