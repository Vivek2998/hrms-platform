# ============================================================
# HRMS Platform — Environment Variables Reference
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in real values in .env
#   3. NEVER commit .env to version control
#   4. Run `node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"` to generate secrets
# ============================================================

# ─────────────────────────────────────────────────────────────
# DATABASE — PostgreSQL 16
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://hrms_user:hrms_password@localhost:5432/hrms_db?schema=public"
# DIRECT_URL bypasses connection pooling — required for Prisma migrations
DIRECT_URL="postgresql://hrms_user:hrms_password@localhost:5432/hrms_db?schema=public"

# ─────────────────────────────────────────────────────────────
# CACHE & QUEUES — Redis 7
# ─────────────────────────────────────────────────────────────
REDIS_URL="redis://:hrms_redis_password@localhost:6379"

# ─────────────────────────────────────────────────────────────
# AUTHENTICATION — JWT
# ─────────────────────────────────────────────────────────────
JWT_SECRET="REPLACE_WITH_64_CHAR_HEX_STRING"
JWT_REFRESH_SECRET="REPLACE_WITH_DIFFERENT_64_CHAR_HEX_STRING"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─────────────────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV="development"
API_BASE_URL="http://localhost:3001"
LOG_LEVEL="debug"

# ─────────────────────────────────────────────────────────────
# WEB FRONTEND (Vite — VITE_ prefix = exposed to browser)
# ─────────────────────────────────────────────────────────────
VITE_API_URL="http://localhost:3001/api/v1"
VITE_WS_URL="ws://localhost:3001"
VITE_APP_NAME="HRMS Platform"
VITE_APP_VERSION="0.1.0"

# ─────────────────────────────────────────────────────────────
# FILE STORAGE — Cloudinary
# ─────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
CLOUDINARY_UPLOAD_PRESET="hrms_unsigned"

# ─────────────────────────────────────────────────────────────
# EMAIL — SMTP (for leave approvals, payslips, onboarding)
# ─────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-gmail-app-password"
SMTP_FROM="HRMS Platform <noreply@yourcompany.com>"

# ─────────────────────────────────────────────────────────────
# PUSH NOTIFICATIONS — Firebase Cloud Messaging (FCM)
# ─────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@your-project.iam.gserviceaccount.com"

# ─────────────────────────────────────────────────────────────
# MULTI-TENANCY — Super Admin
# Bootstrapped on first run (seed script), NOT a regular user
# ─────────────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL="superadmin@hrmsplatform.com"
SUPER_ADMIN_PASSWORD="REPLACE_WITH_STRONG_PASSWORD_MIN_16_CHARS"

# ─────────────────────────────────────────────────────────────
# CORS & APP URLS
# ─────────────────────────────────────────────────────────────
WEB_APP_URL="http://localhost:5173"
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"
MOBILE_DEEP_LINK_SCHEME="hrms"

# ─────────────────────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─────────────────────────────────────────────────────────────
# BULL BOARD — Job queue dashboard (admin access only)
# Access at: http://localhost:3001/admin/queues
# ─────────────────────────────────────────────────────────────
BULL_BOARD_USERNAME="admin"
BULL_BOARD_PASSWORD="REPLACE_WITH_STRONG_PASSWORD"

# ─────────────────────────────────────────────────────────────
# GEOFENCING — Attendance punch-in radius validation
# ─────────────────────────────────────────────────────────────
DEFAULT_GEOFENCE_RADIUS_METERS=200
